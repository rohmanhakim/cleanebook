{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "cleanebook",
	"compatibility_date": "2024-09-23",
	"compatibility_flags": ["nodejs_compat"],
	"pages_build_output_dir": ".svelte-kit/cloudflare",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "cleanebook-db",
			"database_id": "db-local",
			"preview_database_id": "db-local"
		}
	],
	"r2_buckets": [
		{
			"binding": "R2",
			"bucket_name": "cleanebook-files-local",
			"preview_bucket_name": "cleanebook-files-local"
		}
	],
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "kv-local",
			"preview_id": "kv-local"
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "QUEUE",
				"queue": "cleanebook-jobs-local"
			}
		]
	}
}